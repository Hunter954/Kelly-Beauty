<%- include('../partials/admin-header') %><header class="page-header"><div><h1>Agenda</h1><p>Visualização diária dos atendimentos.</p></div><form><input type="date" name="date" value="<%= date %>" onchange="this.form.submit()"></form></header><section class="panel"><% if(!rows.length){ %><div class="empty-state"><i class="bi bi-calendar2-heart"></i><strong>Agenda livre neste dia</strong><span>Os novos agendamentos aparecerão aqui.</span></div><% }else{ %><table><thead><tr><th>Horário</th><th>Cliente</th><th>Serviço</th><th>Profissional</th><th>Status</th><th>Ações</th></tr></thead><tbody><% rows.forEach(a=>{ %><tr><td><strong><%= new Date(a.starts_at).toLocaleTimeString('pt-BR',{timeZone:'America/Sao_Paulo',hour:'2-digit',minute:'2-digit'}) %></strong></td><td><%= a.client_name %><br><small><%= formatPhone(a) %></small></td><td><%= a.service_name %></td><td><%= a.professional_name %></td><td><span class="pill"><%= a.status %></span></td><td><form method="post" action="/admin/appointments/<%= a.id %>/status"><input type="hidden" name="returnTo" value="/admin/agenda?date=<%= date %>"><select name="status"><option value="confirmed">Confirmado</option><option value="in_progress">Em atendimento</option><option value="completed">Concluído</option><option value="no_show">Não compareceu</option><option value="cancelled_by_business">Cancelar</option></select><button>Atualizar</button></form></td></tr><% }) %></tbody></table><% } %></section><%- include('../partials/admin-footer') %>

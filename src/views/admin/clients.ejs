<%- include('../partials/admin-header') %><header class="page-header"><div><h1>Clientes</h1><p>Contatos, histórico e próximos horários.</p></div><form><input name="q" value="<%= q %>" placeholder="Buscar nome ou telefone"></form></header><section class="panel"><table><thead><tr><th>Cliente</th><th>Telefone</th><th>Agendamentos</th><th>Última interação</th></tr></thead><tbody><% rows.forEach(u=>{ %><tr><td><strong><%= u.name || 'Nome não informado' %></strong></td><td><%= formatPhone(u) %></td><td><%= u.appointment_count %></td><td><%= new Date(u.last_interaction_at).toLocaleString('pt-BR',{timeZone:'America/Sao_Paulo'}) %></td></tr><% }) %></tbody></table></section><%- include('../partials/admin-footer') %>

<%- include('../partials/admin-header') %><header class="page-header"><div><h1>Configurações</h1><p>Dados do estabelecimento e mensagens do WhatsApp.</p></div></header><% if(saved){ %><div class="alert success">Configurações salvas.</div><% } %><div class="panel narrow"><form method="post" class="stacked"><label>Usuário do painel<input name="admin_user" value="<%= settings.admin_user||'admin' %>" required></label><label>Nova senha<input type="password" name="new_password" minlength="8" placeholder="Deixe vazio para manter"></label><label>Nome do estabelecimento<input name="business_name" value="<%= settings.business_name||'' %>"></label><label>Telefone<input name="business_phone" value="<%= settings.business_phone||'' %>"></label><label>Instagram<input name="business_instagram" value="<%= settings.business_instagram||'' %>"></label><label>Endereço<input name="business_address" value="<%= settings.business_address||'' %>"></label><label>Mensagem de boas-vindas<textarea name="welcome_message" rows="10"><%= settings.welcome_message||'' %></textarea></label><button class="primary">Salvar configurações</button></form></div><%- include('../partials/admin-footer') %>

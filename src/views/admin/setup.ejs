<!doctype html><html lang="pt-BR"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Configuração inicial Kelly Beauty</title><link rel="stylesheet" href="/public/admin.css"></head><body class="login-page"><section class="login-card"><h1>Kelly Rodrigues Beauty Studio</h1><p>Crie o primeiro acesso administrativo.</p><% if(error){ %><div class="alert"><strong>Não foi possível salvar:</strong><br><%= error %></div><% } %><% if(database){ %><div class="muted" style="font-size:.85rem;margin-bottom:1rem">Banco: <%= database.configured ? (database.activeSource || 'configurado') : 'não configurado' %><% if(database.target){ %> — <%= database.target %><% } %></div><% } %><form method="post"><label>Usuário<input name="username" value="admin" required></label><label>Senha<input type="password" name="password" minlength="8" required></label><label>Confirmar senha<input type="password" name="confirm_password" minlength="8" required></label><button class="primary">Salvar e entrar</button></form><p class="muted" style="font-size:.8rem;margin-top:1rem">No Railway, use DATABASE_URL=${{Postgres.DATABASE_URL}} e monte o volume em /data.</p></section></body></html>
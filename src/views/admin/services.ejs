<%- include('../partials/admin-header') %><header class="page-header"><div><h1>Serviços</h1><p>Configure duração e preço antes de liberar a agenda.</p></div></header><% if(saved){ %><div class="alert success">Serviço atualizado.</div><% } %><section class="service-grid"><% rows.forEach(s=>{ %><form class="panel stacked" method="post" action="/admin/services/<%= s.id %>"><h2><%= s.name %></h2><small><%= s.category_name %></small><label>Descrição<textarea name="description"><%= s.description||'' %></textarea></label><div class="form-grid"><label>Duração (min)<input type="number" min="15" step="5" name="duration_minutes" value="<%= s.duration_minutes||'' %>" required></label><label>Intervalo adicional<input type="number" min="0" step="5" name="buffer_minutes" value="<%= s.buffer_minutes||0 %>"></label><label>Preço (R$)<input name="price" value="<%= s.price_cents!=null?(s.price_cents/100).toFixed(2).replace('.',','):'' %>"></label><label>Exibição do preço<select name="price_type"><option value="hidden" <%= s.price_type==='hidden'?'selected':'' %>>Oculto</option><option value="exact" <%= s.price_type==='exact'?'selected':'' %>>Valor exato</option><option value="from" <%= s.price_type==='from'?'selected':'' %>>A partir de</option><option value="consult" <%= s.price_type==='consult'?'selected':'' %>>Sob consulta</option></select></label></div><label class="check"><input type="checkbox" name="active" <%= s.active?'checked':'' %>> Serviço ativo</label><button class="primary">Salvar serviço</button></form><% }) %></section><%- include('../partials/admin-footer') %>

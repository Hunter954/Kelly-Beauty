<%- include('../partials/admin-header') %><header class="page-header"><div><h1>Agendamentos</h1><p>Histórico completo sem exclusão de cancelamentos.</p></div></header><section class="panel"><table><thead><tr><th>Código</th><th>Data</th><th>Cliente</th><th>Serviço</th><th>Status</th></tr></thead><tbody><% rows.forEach(a=>{ %><tr><td><strong><%= a.public_code %></strong></td><td><%= new Date(a.starts_at).toLocaleString('pt-BR',{timeZone:'America/Sao_Paulo'}) %></td><td><%= a.client_name %><br><small><%= formatPhone(a) %></small></td><td><%= a.service_name %><br><small><%= a.professional_name %></small></td><td><span class="pill"><%= a.status %></span></td></tr><% }) %></tbody></table></section><%- include('../partials/admin-footer') %>

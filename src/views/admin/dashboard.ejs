<%- include('../partials/admin-header') %><header class="page-header"><div><h1>Visão geral</h1><p>Agenda, clientes e atendimento em um só lugar.</p></div><a href="/admin/agenda"><button class="primary">Abrir agenda</button></a></header>
<section class="grid stats"><article><strong><%= stats.today %></strong><span>Agendamentos hoje</span></article><article><strong><%= stats.week %></strong><span>Esta semana</span></article><article><strong><%= stats.confirmed %></strong><span>Confirmados</span></article><article><strong><%= stats.new_clients %></strong><span>Novas clientes no mês</span></article><article><strong><%= stats.support_open %></strong><span>Conversas aguardando</span></article></section>
<div class="two-columns"><section class="panel"><h2>Agenda de hoje</h2><% if(!today.length){ %><p class="muted">Nenhum atendimento agendado para hoje.</p><% } else { %><table><thead><tr><th>Horário</th><th>Cliente</th><th>Serviço</th><th>Status</th></tr></thead><tbody><% today.forEach(a=>{ %><tr><td><%= new Date(a.starts_at).toLocaleTimeString('pt-BR',{timeZone:'America/Sao_Paulo',hour:'2-digit',minute:'2-digit'}) %></td><td><%= a.client_name || 'Cliente' %></td><td><%= a.service_name %></td><td><span class="pill"><%= a.status %></span></td></tr><% }) %></tbody></table><% } %></section><section class="panel"><h2>Resumo financeiro</h2><p class="metric">R$ <%= (Number(stats.forecast_cents)/100).toFixed(2).replace('.',',') %></p><p class="muted">Faturamento previsto no mês, sem depender de pagamento antecipado.</p><h2>WhatsApp</h2><div class="status <%= bot.ready?'ok':'warn' %>"><%= bot.status %></div></section></div><%- include('../partials/admin-footer') %>
